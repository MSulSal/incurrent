{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://incurrent.local/specs/json/increment-request.schema.json",
  "title": "IncrementRequest",
  "type": "object",
  "additionalProperties": false,
  "required": ["delta", "op_id"],
  "properties": {
    "delta": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10000
    },
    "op_id": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[47][0-9a-fA-F]{3}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    }
  }
}
