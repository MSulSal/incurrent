{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://incurrent.local/specs/json/error-response.schema.json",
  "title": "ErrorResponse",
  "type": "object",
  "additionalProperties": false,
  "required": ["error", "message", "request_id"],
  "properties": {
    "error": {
      "type": "string",
      "enum": [
        "validation_error",
        "unsupported_media_type",
        "rate_limited",
        "internal_error"
      ]
    },
    "message": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "request_id": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    }
  }
}
